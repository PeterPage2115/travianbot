# Production environment configuration
# Copy this to .env.production for production deployment

# Discord application
DISCORD_TOKEN=your_production_bot_token_here
DISCORD_CLIENT_ID=your_production_discord_application_client_id
DISCORD_GUILD_ID=
ADMIN_ROLE_ID=

# Production database URL
# Use secure credentials and connection string
DATABASE_URL=postgresql://user:password@production-host:5432/travianbot_prod

# Travian server
TRAVIAN_SERVER_URL=https://rof.x3.international.travian.com
MAP_SQL_URL=https://rof.x3.international.travian.com/map.sql

# Production defaults
NODE_ENV=production
LOG_LEVEL=info

# Server configuration
SERVER_ID=1

# Inactive heuristics
INACTIVITY_LOOKBACK_SNAPSHOTS=5
INACTIVITY_ZERO_GROWTH_THRESHOLD=0
INACTIVITY_SMALL_GROWTH_THRESHOLD=50
INACTIVITY_SMALL_GROWTH_SCORE=3
