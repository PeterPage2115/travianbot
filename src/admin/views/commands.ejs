<div class="page-header">
  <h1>Command Logs</h1>
  <span class="last-update"><%= logs.length %> entries</span>
</div>

<div class="table-card full-width">
  <table class="log-table">
    <thead>
      <tr>
        <th>Time</th>
        <th>User</th>
        <th>Guild</th>
        <th>Command</th>
        <th>Status</th>
        <th>Duration</th>
        <th>Error</th>
      </tr>
    </thead>
    <tbody>
      <% logs.forEach(cmd => { %>
        <tr>
          <td><%= new Date(cmd.timestamp).toLocaleString() %></td>
          <td><%= cmd.userName %></td>
          <td><%= cmd.guildName || '-' %></td>
          <td><code>/<%= cmd.commandName %></code></td>
          <td><span class="badge <%= cmd.success ? 'success' : 'error' %>"><%= cmd.success ? '✓ OK' : '✗ Error' %></span></td>
          <td><%= cmd.durationMs %>ms</td>
          <td class="error-text"><%= cmd.errorMessage || '-' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
