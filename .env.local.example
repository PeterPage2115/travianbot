# Local development environment configuration
# Copy this to .env.local for local development

# Discord application for testing
DISCORD_TOKEN=your_test_bot_token_here
DISCORD_CLIENT_ID=your_test_discord_application_client_id
DISCORD_GUILD_ID=your_test_guild_id
ADMIN_ROLE_ID=

# Local development database
DATABASE_URL=postgresql://localhost:5432/travianbot_dev

# Travian server
TRAVIAN_SERVER_URL=https://rof.x3.international.travian.com
MAP_SQL_URL=https://rof.x3.international.travian.com/map.sql

# Development defaults
NODE_ENV=development
LOG_LEVEL=debug

# Server configuration
SERVER_ID=1

# Inactive heuristics
INACTIVITY_LOOKBACK_SNAPSHOTS=5
INACTIVITY_ZERO_GROWTH_THRESHOLD=0
INACTIVITY_SMALL_GROWTH_THRESHOLD=50
INACTIVITY_SMALL_GROWTH_SCORE=3
