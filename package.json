{
  "name": "travianbot",
  "version": "1.0.0",
  "description": "Travian Discord Bot",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "dev": "tsx src/index.ts",
    "dev:local": "cross-env NODE_ENV=development ENV_FILE=.env.local tsx src/index.ts",
    "start": "node dist/index.js",
    "start:production": "cross-env NODE_ENV=production ENV_FILE=.env.production node dist/index.js",
    "ci:test": "vitest run",
    "ci:build": "npm run typecheck && npm run build"
  },
  "keywords": [
    "discord",
    "bot",
    "travian"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "cross-env": "^10.1.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
