# General environment template
# Copy this to .env, .env.local, or .env.production and fill in values

# Discord application
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=
ADMIN_ROLE_ID=

# Database
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/travianbot

# Travian server
TRAVIAN_SERVER_URL=https://rof.x3.international.travian.com
MAP_SQL_URL=https://rof.x3.international.travian.com/map.sql

# App defaults
# Options: development, production, test
NODE_ENV=development
LOG_LEVEL=info
DEFAULT_LANGUAGE=pl

# Server configuration
SERVER_ID=1

# Inactive heuristics
INACTIVITY_LOOKBACK_SNAPSHOTS=5
INACTIVITY_ZERO_GROWTH_THRESHOLD=0
INACTIVITY_SMALL_GROWTH_THRESHOLD=50
INACTIVITY_SMALL_GROWTH_SCORE=3

# Admin panel (local only, no auth needed)
ADMIN_PORT=3001
